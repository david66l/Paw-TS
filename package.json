{
  "name": "paw",
  "private": true,
  "type": "module",
  "description": "Paw TypeScript stack (canonical). Lives under paw-ts/ only — do not import ../src/paw. Spec: 架构设计v2.",
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "typecheck": "bun run typecheck:core && bun run typecheck:settings && bun run typecheck:workspace && bun run typecheck:harness && bun run typecheck:models && bun run typecheck:store && bun run typecheck:agent && bun run typecheck:cli-core && bun run typecheck:cli && bun run typecheck:tui",
    "typecheck:core": "cd packages/core && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:settings": "cd packages/settings && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:workspace": "cd packages/workspace && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:harness": "cd packages/harness && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:models": "cd packages/models && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:store": "cd packages/store && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:agent": "cd packages/agent && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:cli-core": "cd packages/cli-core && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:cli": "cd apps/cli && bunx tsc --noEmit -p tsconfig.json",
    "typecheck:tui": "cd apps/tui && bunx tsc --noEmit -p tsconfig.json",
    "lint": "biome check packages apps",
    "lint:fix": "biome check --write packages apps",
    "test:ts": "bun test packages/core packages/settings packages/workspace packages/harness packages/models packages/store packages/agent packages/cli-core apps/cli apps/tui",
    "cli": "bun run apps/cli/src/main.ts",
    "tui": "cd apps/tui && bun run src/main.tsx",
    "tui:e2e": "cd apps/tui && bun run e2e:live",
    "check:ts": "bun run lint && bun run typecheck && bun run test:ts",
    "benchmark": "bun test benchmarks/",
    "benchmark:judge": "bun test benchmarks/judge/",
    "benchmark:swe": "cd benchmarks/swe-bench && python run.py",
    "benchmark:repo": "bun test benchmarks/repobench/",
    "benchmark:long": "bun test benchmarks/longbench/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "bun-types": "^1.3.13",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "tiktoken": "^1.0.22"
  }
}
