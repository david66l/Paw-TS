{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "types": ["bun-types", "node"]
  },
  "include": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts"]
}
